# Dependencies — reinstalled inside the container
node_modules/

# Build output — rebuilt inside the container
dist/

# Git history — not needed in the image
.git/
.gitignore

# Local env files — secrets must never go into Docker images.
# Pass VITE_PB_URL as a Railway Build Variable instead.
.env
.env.local
.env.*.local

# Editor and OS files
.vscode/
.idea/
.DS_Store
Thumbs.db

# PocketBase local data — never commit or include in images
pb_data/

# Logs
*.log

# Test and lint artifacts
coverage/
.eslintcache

# README and docs — not needed at runtime
README.md